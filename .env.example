# News APIs
GUARDIAN_API_KEY=your-guardian-api-key
ABC_NEWS_API_KEY=your-abc-news-api-key
ABC_NEWS_API_URL=https://api.abc.net.au/news
SBS_NEWS_API_KEY=your-sbs-news-api-key
SBS_NEWS_API_URL=https://api.sbs.com.au/news
NYT_NEWS_API_KEY=your-nyt-news-api-key
NYT_NEWS_API_URL=https://api.nytimes.com/svc/topstories/v2/home.json

# Local ingest controls
INGEST_PER_SOURCE=10
# INGEST_SOURCE_IDS=guardian,abc,sbs

# AWS / S3
NEWS_DATA_STORAGE_MODE=local-file
AWS_REGION=ap-southeast-2
NEWS_DATA_BUCKET=your-news-data-bucket
NEWS_DATA_RAW_KEY=raw/raw-articles.json
NEWS_DATA_CLEAN_KEY=clean/clean-articles.json
RUNTIME_CACHE_TTL_SECONDS=300

# Optional local ports
DATA_COLLECTION_PORT=8000
RUNTIME_UI_PORT=4173
